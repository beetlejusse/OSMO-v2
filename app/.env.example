# Copy to .env and fill in VITE_TEST_ISSUER_SECRET (the rest is public data,
# safe as committed here). Full reference + explorer links: docs/DEPLOYMENT.md

VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# Issuer of the self-issued tst* classic assets (nebula-test-issuer) - needed
# to build change_trust operations for them (classic assets require a
# trustline before an account can hold them; XLM needs none).
VITE_TEST_ISSUER=GDIYTKW2SS3OVYPHZJ2QOJSSKVPME5GQLRHDJNZ3OZRP6QJHAEFXTZT3

# TESTNET ONLY - powers the in-app faucet (lib/faucet.ts). Get the real value
# with: stellar keys secret nebula-test-issuer
# NEVER embed a mainnet issuer secret client-side - see docs/DEPLOYMENT.md.
VITE_TEST_ISSUER_SECRET=

